# =====================================================
# ShopZone Environment Variables
# =====================================================
# Copy this file to `.env` for local development, or set these
# in the Vercel dashboard (Settings → Environment Variables).

# Local development uses SQLite (file-based, no setup needed).
DATABASE_URL="file:./dev.db"

# =====================================================
# FOR VERCEL DEPLOYMENT
# =====================================================
# Use a PostgreSQL connection string from Vercel Postgres, Neon, or Supabase.
# The vercel.json build command automatically swaps in prisma/schema.vercel.prisma
# (which uses provider = "postgresql") before building.
#
# Example (Neon):
# DATABASE_URL="postgres://default:xxxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"
#
# Example (Vercel Postgres):
# DATABASE_URL="postgres://default:xxxxx@xxx.db.postgres.vercel-storage.com/db"
#
# Example (Supabase):
# DATABASE_URL="postgresql://postgres:xxxxx@db.xxxx.supabase.co:5432/postgres"
